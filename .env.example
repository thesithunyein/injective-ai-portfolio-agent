# Casper Network Configuration
NEXT_PUBLIC_CASPER_NETWORK=testnet
NEXT_PUBLIC_CSPR_CLOUD_API_KEY=your_cspr_cloud_api_key_here

# AI Analysis (Required for real Claude AI integration)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# x402 Configuration (Optional - for production micropayments)
NEXT_PUBLIC_X402_RECIPIENT=your_casper_wallet_address_here

# x402 Facilitator (set to a real Casper x402 Facilitator URL for on-chain settlement)
X402_FACILITATOR_URL=

# Smart Contract (Update after deployment — see DEPLOY_CONTRACT.md)
PORTFOLIO_AGENT_PACKAGE_HASH=your_contract_package_hash_here

# Agent On-Chain Writer (server-side only — fund a Casper Testnet key, then add its PEM or hex here)
# Use CASPER_AGENT_PRIVATE_KEY_PEM for PEM format, or CASPER_AGENT_PRIVATE_KEY_HEX for hex
CASPER_AGENT_PRIVATE_KEY_PEM=
CASPER_AGENT_PRIVATE_KEY_HEX=
# CASPER_AGENT_KEY_ALGORITHM=ed25519  # or secp256k1
